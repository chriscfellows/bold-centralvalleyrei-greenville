# Tampa Site Environment Variables
# Copy to .env.local and fill in values

# BLP PostgreSQL connection (read-only for config/blog/testimonials, narrow write for notifications)
DATABASE_URL=postgresql://user:password@host:5432/blp_db

# BLP Redis connection for BullMQ lead-ingestion queue
REDIS_URL=redis://user:password@host:6379

# BLP website ID for this site (set in BLP admin)
WEBSITE_ID=1

# SendGrid API key for error email fallback
SENDGRID_API_KEY=SG.xxxx

# Public domain (used in canonical URLs)
NEXT_PUBLIC_DOMAIN=tampaflcashbuyers.com
